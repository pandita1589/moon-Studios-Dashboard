{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "moon Studios",
  "version": "1.0.0",
  "identifier": "com.moonstudios.dashboard",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "moon Studios — Portal Oficial",
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/pandita1589/moon-Studios-Dashboard/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4N0UyOTY5N0QyNDlCMzkKUldRNW15UjlhU2wrNkNDNGp0RTkzQUppdjI2UjZMMStNNnl6UFdyRnJYSWg2YXVRYmJmaGVVbFQK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "© 2026 moon Studios. Todos los derechos reservados.",
    "category": "Business",
    "shortDescription": "Portal corporativo moon Studios",
    "longDescription": "Plataforma digital corporativa de moon Studios. Gestión interna, credenciales y sistema empresarial.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "languages": ["Spanish"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}